{
    "name": "hamzi/nativerag",
    "description": "Native Local AI Controller and Retrieval-Augmented Generation (RAG) engine designed specifically for Laravel 11+.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Hamzi",
            "email": "hamzi@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0",
        "illuminate/database": "^11.0",
        "illuminate/http": "^11.0",
        "symfony/http-foundation": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Hamzi\\NativeRag\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hamzi\\NativeRag\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hamzi\\NativeRag\\NativeRagServiceProvider"
            ],
            "aliases": {
                "NativeRag": "Hamzi\\NativeRag\\Facades\\NativeRag"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
